<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="dev.lhl.query.mapper.AsyncQueryTaskMapper">
    <resultMap type="AsyncQueryTask" id="AsyncQueryTaskResult">
        <result property="id" column="id" />
        <result property="queryId" column="query_id" />
        <result property="userId" column="user_id" />
        <result property="status" column="status" />
        <result property="progress" column="progress" />
        <result property="errorMessage" column="error_message" />
        <result property="startTime" column="start_time" />
        <result property="endTime" column="end_time" />
        <result property="executionTime" column="execution_time" />
        <result property="createTime" column="create_time" />
    </resultMap>
    <sql id="selectAsyncQueryTaskVo">
        select id, query_id, user_id, status, progress, error_message, 
               start_time, end_time, execution_time, create_time 
        from bi_async_query_task
    </sql>
    <select id="selectAsyncQueryTaskList" parameterType="AsyncQueryTask" resultMap="AsyncQueryTaskResult">
        <include refid="selectAsyncQueryTaskVo"/>
        <where>
            <if test="queryId != null">and query_id = #{queryId}</if>
            <if test="userId != null">and user_id = #{userId}</if>
            <if test="status != null and status != ''">and status = #{status}</if>
        </where>
        order by create_time desc
    </select>
    <select id="selectAsyncQueryTaskById" parameterType="Long" resultMap="AsyncQueryTaskResult">
        <include refid="selectAsyncQueryTaskVo"/>
        where id = #{id}
    </select>
    <select id="selectAsyncQueryTaskByQueryId" parameterType="Long" resultMap="AsyncQueryTaskResult">
        <include refid="selectAsyncQueryTaskVo"/>
        where query_id = #{queryId}
    </select>
    <insert id="insertAsyncQueryTask" parameterType="AsyncQueryTask" useGeneratedKeys="true" keyProperty="id">
        insert into bi_async_query_task
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="queryId != null">query_id,</if>
            <if test="userId != null">user_id,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="progress != null">progress,</if>
            <if test="errorMessage != null">error_message,</if>
            <if test="startTime != null">start_time,</if>
            <if test="endTime != null">end_time,</if>
            <if test="executionTime != null">execution_time,</if>
            <if test="createTime != null">create_time,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="queryId != null">#{queryId},</if>
            <if test="userId != null">#{userId},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="progress != null">#{progress},</if>
            <if test="errorMessage != null">#{errorMessage},</if>
            <if test="startTime != null">#{startTime},</if>
            <if test="endTime != null">#{endTime},</if>
            <if test="executionTime != null">#{executionTime},</if>
            <if test="createTime != null">#{createTime},</if>
        </trim>
    </insert>
    <update id="updateAsyncQueryTask" parameterType="AsyncQueryTask">
        update bi_async_query_task
        <trim prefix="SET" suffixOverrides=",">
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="progress != null">progress = #{progress},</if>
            <if test="errorMessage != null">error_message = #{errorMessage},</if>
            <if test="startTime != null">start_time = #{startTime},</if>
            <if test="endTime != null">end_time = #{endTime},</if>
            <if test="executionTime != null">execution_time = #{executionTime},</if>
        </trim>
        where id = #{id}
    </update>
    <delete id="deleteAsyncQueryTaskById" parameterType="Long">
        delete from bi_async_query_task where id = #{id}
    </delete>
    <delete id="deleteAsyncQueryTaskByIds" parameterType="String">
        delete from bi_async_query_task where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>
