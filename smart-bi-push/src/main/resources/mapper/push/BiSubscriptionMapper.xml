<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="dev.lhl.push.mapper.BiSubscriptionMapper">
    <resultMap type="dev.lhl.push.domain.BiSubscription" id="BiSubscriptionResult">
        <result property="id" column="id" />
        <result property="userId" column="user_id" />
        <result property="subscribeType" column="subscribe_type" />
        <result property="targetId" column="target_id" />
        <result property="scheduleCron" column="schedule_cron" />
        <result property="receiveChannels" column="receive_channels" />
        <result property="status" column="status" />
        <result property="createBy" column="create_by" />
        <result property="createTime" column="create_time" />
        <result property="updateBy" column="update_by" />
        <result property="updateTime" column="update_time" />
        <result property="remark" column="remark" />
    </resultMap>
    <sql id="selectBiSubscriptionVo">
        select id, user_id, subscribe_type, target_id, schedule_cron, receive_channels, status,
               create_by, create_time, update_by, update_time, remark from bi_subscription
    </sql>
    <select id="selectById" resultMap="BiSubscriptionResult">
        <include refid="selectBiSubscriptionVo"/> where id = #{id}
    </select>
    <select id="selectList" resultMap="BiSubscriptionResult">
        <include refid="selectBiSubscriptionVo"/>
        <where>
            <if test="userId != null">and user_id = #{userId}</if>
            <if test="subscribeType != null and subscribeType != ''">and subscribe_type = #{subscribeType}</if>
            <if test="status != null and status != ''">and status = #{status}</if>
        </where>
        order by id desc
    </select>
    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        insert into bi_subscription (user_id, subscribe_type, target_id, schedule_cron, receive_channels, status, create_by, create_time, remark)
        values (#{userId}, #{subscribeType}, #{targetId}, #{scheduleCron}, #{receiveChannels}, #{status}, #{createBy}, #{createTime}, #{remark})
    </insert>
    <update id="updateById">
        update bi_subscription
        <set>
            <if test="subscribeType != null">subscribe_type = #{subscribeType},</if>
            <if test="targetId != null">target_id = #{targetId},</if>
            <if test="scheduleCron != null">schedule_cron = #{scheduleCron},</if>
            <if test="receiveChannels != null">receive_channels = #{receiveChannels},</if>
            <if test="status != null">status = #{status},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </set>
        where id = #{id}
    </update>
    <delete id="deleteById">delete from bi_subscription where id = #{id}</delete>
    <delete id="deleteByIds">
        delete from bi_subscription where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">#{id}</foreach>
    </delete>
</mapper>
