<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="dev.lhl.dashboard.mapper.ShareLinkMapper">
    <resultMap type="ShareLink" id="ShareLinkResult">
        <result property="id" column="id" />
        <result property="shareKey" column="share_key" />
        <result property="resourceType" column="resource_type" />
        <result property="resourceId" column="resource_id" />
        <result property="userId" column="user_id" />
        <result property="password" column="password" />
        <result property="expireTime" column="expire_time" />
        <result property="accessCount" column="access_count" />
        <result property="maxAccessCount" column="max_access_count" />
        <result property="status" column="status" />
        <result property="createBy" column="create_by" />
        <result property="createTime" column="create_time" />
        <result property="updateBy" column="update_by" />
        <result property="updateTime" column="update_time" />
        <result property="remark" column="remark" />
    </resultMap>
    <sql id="selectShareLinkVo">
        select id, share_key, resource_type, resource_id, user_id, password, expire_time, 
               access_count, max_access_count, status, create_by, create_time, update_by, update_time, remark 
        from bi_share_link
    </sql>
    <select id="selectShareLinkList" parameterType="ShareLink" resultMap="ShareLinkResult">
        <include refid="selectShareLinkVo"/>
        <where>
            <if test="shareKey != null and shareKey != ''">and share_key = #{shareKey}</if>
            <if test="resourceType != null and resourceType != ''">and resource_type = #{resourceType}</if>
            <if test="resourceId != null">and resource_id = #{resourceId}</if>
            <if test="userId != null">and user_id = #{userId}</if>
            <if test="status != null and status != ''">and status = #{status}</if>
        </where>
        order by create_time desc
    </select>
    <select id="selectShareLinkById" parameterType="Long" resultMap="ShareLinkResult">
        <include refid="selectShareLinkVo"/>
        where id = #{id}
    </select>
    <select id="selectShareLinkByShareKey" parameterType="String" resultMap="ShareLinkResult">
        <include refid="selectShareLinkVo"/>
        where share_key = #{shareKey}
    </select>
    <insert id="insertShareLink" parameterType="ShareLink" useGeneratedKeys="true" keyProperty="id">
        insert into bi_share_link
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="shareKey != null and shareKey != ''">share_key,</if>
            <if test="resourceType != null and resourceType != ''">resource_type,</if>
            <if test="resourceId != null">resource_id,</if>
            <if test="userId != null">user_id,</if>
            <if test="password != null">password,</if>
            <if test="expireTime != null">expire_time,</if>
            <if test="accessCount != null">access_count,</if>
            <if test="maxAccessCount != null">max_access_count,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="remark != null">remark,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="shareKey != null and shareKey != ''">#{shareKey},</if>
            <if test="resourceType != null and resourceType != ''">#{resourceType},</if>
            <if test="resourceId != null">#{resourceId},</if>
            <if test="userId != null">#{userId},</if>
            <if test="password != null">#{password},</if>
            <if test="expireTime != null">#{expireTime},</if>
            <if test="accessCount != null">#{accessCount},</if>
            <if test="maxAccessCount != null">#{maxAccessCount},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="remark != null">#{remark},</if>
        </trim>
    </insert>
    <update id="updateShareLink" parameterType="ShareLink">
        update bi_share_link
        <trim prefix="SET" suffixOverrides=",">
            <if test="password != null">password = #{password},</if>
            <if test="expireTime != null">expire_time = #{expireTime},</if>
            <if test="accessCount != null">access_count = #{accessCount},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where id = #{id}
    </update>
    <update id="incrementAccessCount" parameterType="String">
        update bi_share_link
        set access_count = access_count + 1
        where share_key = #{shareKey}
    </update>
    <delete id="deleteShareLinkById" parameterType="Long">
        delete from bi_share_link where id = #{id}
    </delete>
    <delete id="deleteShareLinkByIds" parameterType="String">
        delete from bi_share_link where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>
